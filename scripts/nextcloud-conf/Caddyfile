# Caddyfile — reverse proxy in front of Nextcloud.
#
# wire-dosbox-engine §1 last-mile: AppAPI's HaRP-mode deploy builds
# ExApp URLs as <nextcloud_url>/exapps/<appid>/<path>. Those need
# to reach HaRP's HTTP frontend on :8780, not NC's PHP app. NC's
# stock image doesn't do this routing; patching its .htaccess is
# fragile (rewritten on upgrade). A real reverse proxy in front
# does the job once and matches what production deployments use.
#
# Routing:
#   /exapps/*  → appapi-harp:8780  (HaRP, ExApp HTTP traffic)
#   anything else → nextcloud:80   (regular NC)

:80 {
    # Send /exapps/* to HaRP first — pattern matching wins by
    # specificity over the catch-all `reverse_proxy nextcloud:80`
    # below.
    handle /exapps/* {
        reverse_proxy appapi-harp:8780 {
            # Keep the original Host header — HaRP doesn't seem to
            # need it but it makes logs less confusing.
            header_up Host {host}
        }
    }

    # Everything else: Nextcloud.
    #
    # Caddy 2.x forwards ALL request headers by default (including
    # Authorization and Cookie), so the explicit `header_up` lines
    # below are defensive — they make the auth-forwarding intent
    # visible in the config and pin behaviour across Caddy minor
    # versions. wire-dosbox-engine debugging confirmed the proxy URL
    # `/index.php/apps/app_api/proxy/ash_nazg/<path>` requires a real
    # NC session: basic-auth via curl only works on OCS endpoints, not
    # on the proxy controller (NC's session middleware kicks in).
    # Test the proxy URL from a logged-in BROWSER session, not curl.
    handle {
        reverse_proxy nextcloud:80 {
            header_up Authorization {http.request.header.Authorization}
            header_up Cookie {http.request.header.Cookie}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-For {remote}
        }
    }

    # Logging stays light — uncomment to debug.
    # log { output stderr }
}
