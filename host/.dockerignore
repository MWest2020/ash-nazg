# Keep the build context lean and exclude test/cache files from the image.
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Tests don't ship in the runtime image; CI runs them in a separate stage.
tests/

# Scratch/editor noise.
.git/
.github/
.idea/
.vscode/
*.swp
.DS_Store

# NOTE: static/ is intentionally NOT excluded — the frontend bundle
# (vite output) is baked into the image so the App Store distribution
# is a single self-contained container. Built locally with
# `cd frontend && npm run build` before docker build.
